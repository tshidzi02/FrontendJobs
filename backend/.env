# =============================================================================
# FILE: backend/.env
# =============================================================================
# PURPOSE: This file stores ALL secret values for the backend.
#          It is NEVER committed to Git. Add ".env" to your .gitignore file.
#          Each line is: KEY=value (no spaces around the = sign)
#
# HOW IT WORKS:
#   1. python-dotenv reads this file when the app starts
#   2. Each key becomes available via os.environ.get("KEY_NAME")
#   3. config.py reads these values and exposes them to app.py
#   4. app.py uses config values — never raw strings
# =============================================================================

# JWT secret key — make this a long random string
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_this_with_a_long_random_string_minimum_32_chars

# Your OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Google OAuth Client ID — get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=522098871996-vuo12fbja9g1gafcuq2cp5r8sg97t7vf.apps.googleusercontent.com

# Database URL — SQLite for development
# For production this becomes: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///users.db

# Flask environment — "development" enables debug mode, "production" disables it
FLASK_ENV=development


JSEARCH_API_KEY=ef17bb15d6msh96b4ac529f226eap134b7ejsn9f9ee48618d1
ADZUNA_APP_ID=c5e4c9a7
ADZUNA_APP_KEY=1b046819846e559d55f087721f33aad9
